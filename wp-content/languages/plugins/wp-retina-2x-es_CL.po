#: classes/rest.php:187
msgid "You cannot use this file (wrong extension? wrong type?)."
msgstr "No puedes usar este archivo (¿extensión incorrecta? ¿tipo incorrecto?)."

#: classes/rest.php:181
msgid "The file is not an image or the upload went wrong."
msgstr "El archivo no es una imagen o la subida fue mal."

#: classes/rest.php:175 classes/rest.php:648 classes/rest.php:692
msgid "You do not have permission to upload files."
msgstr "No tienes permisos para subir archivos."

#: classes/core.php:1030
msgid "This size is ignored by your retina settings."
msgstr "Este tamaño es ignorado por los ajustes de retina."

#: classes/core.php:1025
msgid "The standard image normally created by WordPress is missing."
msgstr "No se encontró la imagen estándar creada habitualmente por WordPress."

#: classes/core.php:1020
msgid "The retina image can be created. Please use the 'GENERATE' button."
msgstr "Se puede crear la imagen retina. Por favor, utiliza el botón “GENERAR”."

#: classes/core.php:1010
msgid "The Full-Size image is too small (<b>%dx%d</b>) and this size cannot be generated.<br />Please upload an image of at least <b>%dx%d</b>."
msgstr "La imagen de tamaño completo es demasiado pequeña (<b>%dx%d</b>) y este tamaño no se puede generar. <br />Por favor, sube una imagen de al menos <b>%dx%d</b>."

#: classes/core.php:1006
msgid "The retina version of the Full-Size image is missing.<br />Full-Size Retina has been checked in the Settings and this image is therefore required.<br />Please drag & drop an image of at least <b>%dx%d</b> in the <b>Full-Size Retina Upload</b> column."
msgstr "Falta la versión retina de la imagen a tamaño completo.<br />La imagen retina de tamaño completo se ha activado en los ajustes y, por tanto, esta imagen es obligatoria.<br />Por favor, arrastra y suelta una imagen de al menos <b>%dx%d</b> en la columna <b>Subir imagen retina de tamaño completo</b>."

#: classes/core.php:988
msgid "The image size '%s' could not be found. You probably changed your image sizes but this specific image was not re-build. This is not related to the retina plugin. You should probably use a plugin to re-generate the missing metadata and images."
msgstr "El tamaño de la imagen '%s' no se pudo encontrar. Es probable que haya cambiado el tamaño de la imagen, pero esta imagen específica no se ha regenerado. Esto no está relacionado con el plugin retina. Probablemente deberías utilizar un plugin para volver a regenerar los metadatos e imágenes que faltan."

#: classes/core.php:984
msgid "The metadata is broken! This is not related to the retina plugin. You should probably use a plugin to re-generate the missing metadata and images."
msgstr "¡Los metadatos están rotos! Esto no está relacionado con el plugin retina. Probablemente deberías utilizar un plugin para volver a generar los metadatos e imágenes que faltan."

